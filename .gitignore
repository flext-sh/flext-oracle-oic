# ============================================================================
# FLEXT-ORACLE-OIC-EXT - Oracle Integration Cloud Extension .gitignore
# Python 3.13 | Poetry | Oracle OIC | REST APIs | Integration
# ============================================================================

# ============================================================================
# JUNK FILES - NEVER COMMIT THESE
# ============================================================================

# Archive and backup directories  
archive/
archives/
backup/
backups/
.backup/
*_backup/
*_backup_*/

# AI-generated files and reports
*_REPORT*.md
*_ANALYSIS*.md
*_SUMMARY*.md  
*_FINDINGS*.md
CLAUDE*.md
CONFIG_MIGRATION*.md
DEVELOPMENT_STANDARDS*.md
DUPLICATION_REPORT*.md
LINT_CORRECTIONS*.md
*.ai.md
*.ai.txt

# Backup files with timestamps
*_20250*.bak
*_202507*.bak
*_202506*.bak
*.md_20250*
README_20250*.bak

# Generic backup patterns
*.bak
*.backup
*.orig
*.syntax_backup  
*.broken
*.tmp.bak
*_temp.py
*_temp.md

# Fix scripts and validation files
fix_*.py
*_fix.py
*_validation.py
validate_*.py
investigate_*.py
temp_*.py
debug_*.py

# Tool reports and analysis
*_analysis.txt
*_report.txt
*_output.txt
analysis_temp/
report_*/
reports/
reports_*/
temp_test_*/

