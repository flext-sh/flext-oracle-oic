__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Testing and coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Development tools
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Virtual environments
.env
.venv/
env/
venv/
ENV/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db
Desktop.ini

