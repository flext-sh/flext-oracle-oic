*.p12
*.jks
*.keystore

# ============================================================================
# TEMPORARY AND CACHE FILES
# ============================================================================

# Logs
*.log
logs/

# Temporary files
*.tmp
temp/
tmp/

# Cache files
cache/
.cache/

# Data files
data/
output/

# Force include critical files
!pyproject.toml
!Makefile
!README.md
!example.wsdl
!example.xsd
!docker-compose.yml